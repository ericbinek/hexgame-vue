{
  "name": "hexgame-vue",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --outfile=main.js --format=esm --sourcemap --servedir=. --watch",
    "build": "esbuild src/main.ts --bundle --outfile=main.js --format=esm --minify",
    "typecheck": "tsc --noEmit",
    "test": "esbuild $(find src -name '*.test.ts') --bundle --platform=node --format=esm --outdir=.test-dist --alias:vitest=./test/vitest-shim.ts && node --test '.test-dist/**/*.js'"
  },
  "dependencies": {
    "@vue/runtime-dom": "3.5.35"
  },
  "devDependencies": {
    "esbuild": "0.28.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d"
}
